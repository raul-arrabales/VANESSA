# Optional local overrides for launcher scripts in ops/local-staging/
# Copy to .env.local to customize.

# Compose file used by launcher scripts (relative to repo root or absolute path)
COMPOSE_FILE=infra/docker-compose.yml

# Default timeout used by start.sh and health.sh --wait
START_TIMEOUT_SECONDS=180

# Default log tail size used by logs.sh
LOG_TAIL_LINES=200

# Optional sample auth seeding values used by seed-users.sh and start.sh --seed-sample-users
SAMPLE_SUPERADMIN_USERNAME=sample-superadmin
SAMPLE_SUPERADMIN_EMAIL=sample-superadmin@local.test
SAMPLE_SUPERADMIN_PASSWORD=sample-superadmin-123
SAMPLE_ADMIN_USERNAME=sample-admin
SAMPLE_ADMIN_EMAIL=sample-admin@local.test
SAMPLE_ADMIN_PASSWORD=sample-admin-123
SAMPLE_USER_USERNAME=sample-user
SAMPLE_USER_EMAIL=sample-user@local.test
SAMPLE_USER_PASSWORD=sample-user-123

# Optional LLM routing hints for local health checks (runtime check enabled in local_only mode)
LLM_ROUTING_MODE=local_only

# llm_runtime accelerator selection:
# - auto: use GPU when nvidia-smi is available, otherwise CPU
# - cpu: force CPU-safe vLLM image/flags
# - gpu: force GPU vLLM image/flags
LLM_RUNTIME_ACCELERATOR=auto

# CPU variant selection:
# - auto: prefer avx512f, otherwise avx2, otherwise unsupported
# - avx2: force AVX2-compatible CPU build
# - avx512: force AVX512 CPU build
LLM_RUNTIME_CPU_VARIANT=auto

# Optional override for the PyTorch CPU wheel index used during local vLLM CPU image builds.
LLM_RUNTIME_CPU_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu

# Pin transformers to a vLLM-compatible release for the CPU image build.
LLM_RUNTIME_CPU_TRANSFORMERS_VERSION=4.51.3

# When true, start.sh may omit llm_runtime on unsupported CPU hosts if routing does not require it.
LLM_RUNTIME_DISABLE_LOCAL_ON_UNSUPPORTED_CPU=false
