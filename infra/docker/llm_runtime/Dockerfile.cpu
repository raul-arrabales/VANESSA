FROM python:3.11-slim AS builder

ARG VLLM_VERSION=v0.8.5
ARG LLM_RUNTIME_CPU_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
ARG LLM_RUNTIME_CPU_TRANSFORMERS_VERSION=4.51.3
ARG VLLM_CPU_DISABLE_AVX512=false
ARG VLLM_CPU_AVX2=true
ARG VLLM_CPU_AVX512=false

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_NO_CACHE_DIR=1 \
    PIP_EXTRA_INDEX_URL=${LLM_RUNTIME_CPU_TORCH_INDEX_URL} \
    CMAKE_DISABLE_FIND_PACKAGE_CUDA=ON \
    VLLM_TARGET_DEVICE=cpu \
    VLLM_CPU_DISABLE_AVX512=${VLLM_CPU_DISABLE_AVX512} \
    VLLM_CPU_AVX2=${VLLM_CPU_AVX2} \
    VLLM_CPU_AVX512=${VLLM_CPU_AVX512}

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    curl \
    git \
    libnuma-dev \
    ninja-build \
    pkg-config \
    && rm -rf /var/lib/apt/lists/*

RUN git clone --depth 1 --branch "${VLLM_VERSION}" https://github.com/vllm-project/vllm.git /src/vllm

WORKDIR /src/vllm

RUN pip install --upgrade pip setuptools wheel packaging
RUN pip install -v --extra-index-url "${LLM_RUNTIME_CPU_TORCH_INDEX_URL}" -r requirements/build.txt
RUN pip install -v --extra-index-url "${LLM_RUNTIME_CPU_TORCH_INDEX_URL}" -r requirements/cpu.txt
RUN pip install -v --extra-index-url "${LLM_RUNTIME_CPU_TORCH_INDEX_URL}" "transformers==${LLM_RUNTIME_CPU_TRANSFORMERS_VERSION}"
RUN VLLM_TARGET_DEVICE=cpu python setup.py bdist_wheel
RUN pip install --extra-index-url "${LLM_RUNTIME_CPU_TORCH_INDEX_URL}" dist/*.whl

FROM python:3.11-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libgomp1 \
    libnuma1 \
    numactl \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local /usr/local
COPY llm_runtime /app/llm_runtime

WORKDIR /app
EXPOSE 8000

ENTRYPOINT ["python", "-m", "uvicorn", "llm_runtime.runtime_app.main:app"]
CMD ["--host", "0.0.0.0", "--port", "8000"]
