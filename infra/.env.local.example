# Copy to infra/.env.local for local-only secret/runtime overrides.
# This file is intentionally not used directly by git-tracked defaults.

# Hugging Face token used by backend discovery/download APIs.
HF_TOKEN=

# Optional overrides for model download runtime behavior.
MODEL_STORAGE_ROOT=/models/llm
MODEL_DOWNLOAD_MAX_WORKERS=2
MODEL_DOWNLOAD_STALE_SECONDS=900
MODEL_DOWNLOAD_ALLOW_PATTERNS_DEFAULT=
MODEL_DOWNLOAD_IGNORE_PATTERNS_DEFAULT=

# Optional host-run frontend dev/e2e proxy target.
# Keep the browser base URL on /api and point Vite's dev proxy at a reachable backend.
# Example for host-run frontend against local-staging backend: http://127.0.0.1:5000
VITE_DEV_PROXY_TARGET=

# Initial runtime profile seed. The navbar/settings toggle can change the DB-backed profile after bootstrap.
# Legacy air_gapped values are normalized to offline during startup.
VANESSA_RUNTIME_PROFILE=offline
# Optional hard lock for the runtime profile.
# Legacy air_gapped values are normalized to offline during startup.
VANESSA_RUNTIME_PROFILE_FORCE=
LLM_RUNTIME_ACCELERATOR=auto
LLM_RUNTIME_CPU_VARIANT=auto
LLM_RUNTIME_CPU_IMAGE=vanessa-llm-runtime-cpu:local
LLM_RUNTIME_GPU_IMAGE=vllm/vllm-openai:latest
LLM_RUNTIME_CPU_VLLM_VERSION=v0.8.5
LLM_RUNTIME_CPU_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
LLM_RUNTIME_CPU_TRANSFORMERS_VERSION=4.51.3
VLLM_CPU_OMP_THREADS_BIND=0-7
LLM_RUNTIME_DISABLE_LOCAL_ON_UNSUPPORTED_CPU=false
