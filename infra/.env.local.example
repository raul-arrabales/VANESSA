# Copy to infra/.env.local for local-only secret/runtime overrides.
# This file is intentionally not used directly by git-tracked defaults.

# Hugging Face token used by backend discovery/download APIs.
HF_TOKEN=

# Optional overrides for model download runtime behavior.
MODEL_STORAGE_ROOT=/models/llm
MODEL_DOWNLOAD_MAX_WORKERS=2
MODEL_DOWNLOAD_STALE_SECONDS=900
MODEL_DOWNLOAD_ALLOW_PATTERNS_DEFAULT=
MODEL_DOWNLOAD_IGNORE_PATTERNS_DEFAULT=
