# Frontend
FRONTEND_PORT=3000
VITE_BACKEND_BASE_URL=/api

# Backend
FLASK_ENV=development
BACKEND_PORT=5000
AGENT_ENGINE_URL=http://agent_engine:7000
AGENT_ENGINE_SERVICE_TOKEN=dev-agent-engine-token
AGENT_EXECUTION_VIA_ENGINE=true
AGENT_EXECUTION_FALLBACK=false
LLM_URL=http://llm:8000
LLM_INFERENCE_RUNTIME_URL=http://llm_runtime_inference:8000
LLM_EMBEDDINGS_RUNTIME_URL=http://llm_runtime_embeddings:8000
LLAMA_CPP_URL=
WEAVIATE_URL=http://weaviate:8080
QDRANT_URL=
DATABASE_URL=postgresql://vanessa:vanessa@postgres:5432/vanessa
SANDBOX_URL=http://sandbox:6000
MCP_GATEWAY_URL=http://mcp_gateway:8080
SEARXNG_URL=http://searxng:8080
SEARXNG_SECRET=change-me-local-searxng-secret
SEARXNG_TIMEOUT_SECONDS=8
SEARXNG_DEFAULT_LANGUAGE=
SEARXNG_DEFAULT_SAFESEARCH=1
SEARXNG_DEFAULT_CATEGORIES=general
SEARXNG_DEFAULT_ENGINES=
CONTEXT_SOURCE_ROOTS=/context_sources
# Initial runtime profile seed. After first bootstrap the DB-backed runtime profile is the live source of truth.
# Legacy air_gapped values are normalized to offline during startup.
VANESSA_RUNTIME_PROFILE=offline
# Optional hard lock for the runtime profile. When set, the UI toggle is disabled and policy checks always use this value.
# Legacy air_gapped values are normalized to offline during startup.
VANESSA_RUNTIME_PROFILE_FORCE=

# LLM routing (local-first, optional cloud)
LLM_ROUTING_MODE=local_only
LLM_LOCAL_BASE_URL=http://llm_runtime_inference:8000/v1
LLM_LOCAL_EMBEDDINGS_BASE_URL=http://llm_runtime_embeddings:8000/v1
# Keep this aligned with LLM_INFERENCE_LOCAL_MODEL_PATH (vLLM /v1/models id in local staging).
LLM_LOCAL_UPSTREAM_MODEL=/models/llm/Qwen--Qwen2.5-0.5B-Instruct
# Optional dedicated embeddings startup preload. Leave these blank unless you intentionally want
# llm_runtime_embeddings to cold-start with a specific embeddings model before Platform Control assigns one.
LLM_LOCAL_EMBEDDINGS_UPSTREAM_MODEL=
LLM_LOCAL_MODEL_PATH=/models/llm/Qwen--Qwen2.5-0.5B-Instruct
LLM_INFERENCE_LOCAL_MODEL_PATH=/models/llm/Qwen--Qwen2.5-0.5B-Instruct
LLM_EMBEDDINGS_LOCAL_MODEL_PATH=
LLM_RUNTIME_ACCELERATOR=cpu
LLM_RUNTIME_CPU_VARIANT=auto
LLM_RUNTIME_CPU_IMAGE=vanessa-llm-runtime-cpu:local
LLM_RUNTIME_GPU_IMAGE=vllm/vllm-openai:latest
LLM_RUNTIME_CPU_VLLM_VERSION=v0.8.5
LLM_RUNTIME_CPU_TORCH_INDEX_URL=https://download.pytorch.org/whl/cpu
LLM_RUNTIME_CPU_TRANSFORMERS_VERSION=4.51.3
LLM_RUNTIME_DISABLE_LOCAL_ON_UNSUPPORTED_CPU=false
LLM_RUNTIME_DEVICE=cpu
LLM_RUNTIME_DTYPE=float
LLM_RUNTIME_GPU_DTYPE=auto
LLM_RUNTIME_SHM_SIZE=4g
VLLM_CPU_KVCACHE_SPACE=8
VLLM_CPU_OMP_THREADS_BIND=0-7
LLAMA_CPP_MODEL_PATH=
LLAMA_CPP_CONTEXT_SIZE=4096
LLM_ENABLE_HF_ROUTER=false
LLM_HF_BASE_URL=https://router.huggingface.co/v1
HF_TOKEN=
MODEL_STORAGE_ROOT=/models/llm
MODEL_DOWNLOAD_MAX_WORKERS=2
MODEL_DOWNLOAD_STALE_SECONDS=900
MODEL_DOWNLOAD_ALLOW_PATTERNS_DEFAULT=
MODEL_DOWNLOAD_IGNORE_PATTERNS_DEFAULT=
LLM_HF_UPSTREAM_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_ENABLE_OPENAI=false
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
LLM_OPENAI_UPSTREAM_MODEL=gpt-4o-mini
LLM_ENABLE_CLOUD_FAILOVER=false
# Shared timeout budget for backend -> llm and llm -> runtime HTTP requests.
LLM_REQUEST_TIMEOUT_SECONDS=60

# Local Auth / JWT
AUTH_JWT_SECRET=change-me-local-secret
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_SECONDS=28800
AUTH_ALLOW_SELF_REGISTER=true
AUTH_BOOTSTRAP_SUPERADMIN_EMAIL=
AUTH_BOOTSTRAP_SUPERADMIN_USERNAME=
AUTH_BOOTSTRAP_SUPERADMIN_PASSWORD=

# Agent engine
AGENT_ENGINE_PORT=7000

# KWS (wake-word)
KWS_URL=http://kws:10400
KWS_PORT=10400
KWS_MODEL_DIR=/models/kws
KWS_CUSTOM_MODEL_DIR=/models/kws/custom
KWS_MODEL_PRELOAD=
KWS_DETECTION_THRESHOLD=0.6
KWS_COOLDOWN_MS=2000
KWS_BACKEND_WEBHOOK_URL=http://backend:5000/voice/wake-events
KWS_WEBHOOK_MAX_RETRIES=3
KWS_WEBHOOK_TIMEOUT_SECONDS=2.0
KWS_REQUIRE_MIC=true
